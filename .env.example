# Application
APP_ENV=production
APP_SECRET_KEY=change-me
DATABASE_URL=sqlite:///./data/netwatcher.db

# UniFi Controller / UniFi Network Server
UNIFI_URL=https://unifi.example.local
UNIFI_USERNAME=netwatcher
UNIFI_PASSWORD=change-me
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false
UNIFI_TIMEOUT_SECONDS=10

# Scanner
SCAN_INTERVAL_SECONDS=300
ALERT_COOLDOWN_SECONDS=21600

# Blocking
UNIFI_DRY_RUN_BLOCKS=true

# Demo / development only — set true to use fixture data instead of a real controller.
# compose.dev.yml sets this automatically for Docker-based local development.
UNIFI_MOCK_MODE=false

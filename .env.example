APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET_KEY=change-me
DATABASE_URL=sqlite:///./data/netwatcher.db

UNIFI_URL=https://unifi.example.local
UNIFI_USERNAME=admin
UNIFI_PASSWORD=change-me
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false
UNIFI_TIMEOUT_SECONDS=10

SCAN_INTERVAL_SECONDS=300
ALERT_COOLDOWN_SECONDS=21600

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me

# For testing without a real controller
UNIFI_MOCK_MODE=true
